# Copy this file to shared-secrets.env and fill in real values.
# shared-secrets.env is gitignored. Never commit real keys.

# Google AI Studio — aistudio.google.com/apikey
GOOGLE_API_KEY=

# Slack bot token — api.slack.com/apps → OAuth & Permissions → Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack channel IDs (not names) — right-click a channel in Slack → Copy link, the ID is the last segment
SLACK_DIGEST_CHANNEL=
SLACK_PREVIEW_CHANNEL=
